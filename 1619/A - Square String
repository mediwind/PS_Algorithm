import sys
input = sys.stdin.readline
 
t = int(input())
for _ in range(t):
    s = input().rstrip()
    n = len(s)
    
    if n % 2:
        print("NO")
    else:
        half = n // 2
        first_half = s[:half]
        second_half = s[half:]
        
        if first_half == second_half:
            print("YES")
        else:
            print("NO")