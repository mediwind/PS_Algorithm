import sys
input = sys.stdin.readline
 
t = int(input().rstrip())
for _ in range(t):
    a, b, c = map(int, input().rstrip().split())
    
    half = abs(a - b)
    n = half * 2
    
    if a > n or b > n or c > n:
        print(-1)
    else:
        if c <= half:
            ans = c + half
        else:
            ans = c - half
        
        print(ans)